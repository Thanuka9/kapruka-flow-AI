# ─────────────────────────────────────────────────────────────
# Kapruka Flow — environment configuration
# Copy to `.env` (backend) and set BACKEND_URL in your frontend host.
# ─────────────────────────────────────────────────────────────

# ── Backend (FastAPI) — MCP-native intelligence engine (no external LLM key needed) ──
APP_VERSION=1.0.0
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# Kapruka MCP endpoint + resilience
MCP_URL=https://mcp.kapruka.com/mcp
MCP_TIMEOUT=30                      # seconds per MCP tool call
MCP_MAX_RETRIES=2                  # extra attempts on failure
MCP_RETRY_BACKOFF=0.75             # backoff base (seconds, multiplied by attempt)

# CORS — comma separated allowed origins. Use your deployed frontend URL(s).
# "*" disables credentials automatically.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Persistence
DB_PATH=./flow.db

# Production safety — keep false for live judging
ALLOW_SIMULATED_CHECKOUT=false
ALLOW_FALLBACK_CATALOG=false

# ── Frontend (Next.js) — set in Vercel/hosting dashboard ──
BACKEND_URL=http://localhost:8000
PROXY_TIMEOUT_MS=120000            # frontend → backend proxy timeout
